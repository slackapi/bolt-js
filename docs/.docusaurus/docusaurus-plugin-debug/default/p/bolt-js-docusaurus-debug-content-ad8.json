{"allContent":{"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/bolt-js/","tagsPath":"/bolt-js/tags","editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content","editUrlLocalized":"https://github.com/slackapi/bolt-js/tree/main/docs/i18n/en/docusaurus-plugin-content-docs/current","isLast":true,"routePriority":-1,"sidebarFilePath":"/Users/helmendorf/docs/bolt-js/docs/sidebars.js","contentPath":"/Users/helmendorf/docs/bolt-js/docs/content","contentPathLocalized":"/Users/helmendorf/docs/bolt-js/docs/i18n/en/docusaurus-plugin-content-docs/current","docs":[{"id":"concepts/acknowledge","title":"Acknowledging requests","description":"Actions, commands, and options requests must always be acknowledged using the ack() function. This lets Slack know that the request was received and updates the Slack user interface accordingly. Depending on the type of request, your acknowledgement may be different. For example, when acknowledging a modal submission you will call ack() with validation errors if the submission contains errors, or with no parameters if the submission is valid.","source":"@site/content/concepts/acknowledge.md","sourceDirName":"concepts","slug":"/concepts/acknowledge","permalink":"/bolt-js/concepts/acknowledge","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/acknowledge.md","tags":[],"version":"current","frontMatter":{"title":"Acknowledging requests","lang":"en","slug":"/concepts/acknowledge"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening to events","permalink":"/bolt-js/concepts/event-listening"},"next":{"title":"Listening & responding to shortcuts","permalink":"/bolt-js/concepts/shortcuts"}},{"id":"concepts/actions","title":"Listening & responding to actions","description":"Your app can listen and respond to user actions like button clicks, and menu selects, using the action method.","source":"@site/content/concepts/actions.md","sourceDirName":"concepts","slug":"/concepts/actions","permalink":"/bolt-js/concepts/actions","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/actions.md","tags":[],"version":"current","frontMatter":{"title":"Listening & responding to actions","lang":"en","slug":"/concepts/actions"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening & responding to commands","permalink":"/bolt-js/concepts/commands"},"next":{"title":"Opening modals","permalink":"/bolt-js/concepts/creating-modals"}},{"id":"concepts/ai-apps","title":"AI Apps","description":"If you don't have a paid workspace for development, you can join the Developer Program and provision a sandbox with access to all Slack features for free.","source":"@site/content/concepts/ai-apps.md","sourceDirName":"concepts","slug":"/concepts/ai-apps","permalink":"/bolt-js/concepts/ai-apps","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/ai-apps.md","tags":[],"version":"current","frontMatter":{"title":"AI Apps","lang":"en","slug":"/concepts/ai-apps"},"sidebar":"sidebarJSBolt","previous":{"title":"Publishing views to App Home","permalink":"/bolt-js/concepts/publishing-views"},"next":{"title":"Custom Steps","permalink":"/bolt-js/concepts/custom-steps"}},{"id":"concepts/authenticating-oauth","title":"Authenticating with OAuth","description":"OAuth allows installation of your app to any workspace and is an important step in distributing your app. This is because each app installation issues unique access tokens with related installation information that can be retrieved for incoming events and used to make scoped API requests.","source":"@site/content/concepts/authenticating-oauth.md","sourceDirName":"concepts","slug":"/concepts/authenticating-oauth","permalink":"/bolt-js/concepts/authenticating-oauth","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/authenticating-oauth.md","tags":[],"version":"current","frontMatter":{"title":"Authenticating with OAuth","lang":"en","slug":"/concepts/authenticating-oauth"},"sidebar":"sidebarJSBolt","previous":{"title":"Adding context","permalink":"/bolt-js/concepts/context"},"next":{"title":"Authorization","permalink":"/bolt-js/concepts/authorization"}},{"id":"concepts/authorization","title":"Authorization","description":"Authorization is the process of deciding which Slack credentials (such as a bot token) should be available while processing a specific incoming request.","source":"@site/content/concepts/authorization.md","sourceDirName":"concepts","slug":"/concepts/authorization","permalink":"/bolt-js/concepts/authorization","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/authorization.md","tags":[],"version":"current","frontMatter":{"title":"Authorization","lang":"en","slug":"/concepts/authorization"},"sidebar":"sidebarJSBolt","previous":{"title":"Authenticating with OAuth","permalink":"/bolt-js/concepts/authenticating-oauth"},"next":{"title":"Token rotation","permalink":"/bolt-js/concepts/token-rotation"}},{"id":"concepts/commands","title":"Listening & responding to commands","description":"Your app can use the command() method to listen to incoming slash command requests. The method requires a commandName of type string or RegExp.","source":"@site/content/concepts/commands.md","sourceDirName":"concepts","slug":"/concepts/commands","permalink":"/bolt-js/concepts/commands","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/commands.md","tags":[],"version":"current","frontMatter":{"title":"Listening & responding to commands","lang":"en","slug":"/concepts/commands"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening & responding to shortcuts","permalink":"/bolt-js/concepts/shortcuts"},"next":{"title":"Listening & responding to actions","permalink":"/bolt-js/concepts/actions"}},{"id":"concepts/context","title":"Adding context","description":"All listeners have access to a context object, which can be used to enrich requests with additional information. For example, perhaps you want to add user information from a third party system or add temporary state for the next middleware in the chain.","source":"@site/content/concepts/context.md","sourceDirName":"concepts","slug":"/concepts/context","permalink":"/bolt-js/concepts/context","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/context.md","tags":[],"version":"current","frontMatter":{"title":"Adding context","lang":"en","slug":"/concepts/context"},"sidebar":"sidebarJSBolt","previous":{"title":"Listener middleware","permalink":"/bolt-js/concepts/listener-middleware"},"next":{"title":"Authenticating with OAuth","permalink":"/bolt-js/concepts/authenticating-oauth"}},{"id":"concepts/creating-modals","title":"Opening modals","description":"Modals are focused surfaces that allow you to collect user data and display dynamic information. You can open a modal by passing a valid trigger_id and a view payload to the built-in client's views.open method.","source":"@site/content/concepts/creating-modals.md","sourceDirName":"concepts","slug":"/concepts/creating-modals","permalink":"/bolt-js/concepts/creating-modals","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/creating-modals.md","tags":[],"version":"current","frontMatter":{"title":"Opening modals","lang":"en","slug":"/concepts/creating-modals"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening & responding to actions","permalink":"/bolt-js/concepts/actions"},"next":{"title":"Updating & pushing views","permalink":"/bolt-js/concepts/updating-pushing-views"}},{"id":"concepts/custom-routes","title":"Adding custom HTTP routes","description":"As of v3.7.0, custom HTTP routes can be easily added by passing in an array of routes as customRoutes when initializing App.","source":"@site/content/concepts/custom-routes.md","sourceDirName":"concepts","slug":"/concepts/custom-routes","permalink":"/bolt-js/concepts/custom-routes","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/custom-routes.md","tags":[],"version":"current","frontMatter":{"title":"Adding custom HTTP routes","lang":"en","slug":"/concepts/custom-routes"},"sidebar":"sidebarJSBolt","previous":{"title":"Logging","permalink":"/bolt-js/concepts/logging"},"next":{"title":"Deferring app initialization","permalink":"/bolt-js/concepts/deferring-initialization"}},{"id":"concepts/custom-steps","title":"Custom Steps","description":"Your app can use the function() method to listen to incoming custom step requests. Custom steps are used in Workflow Builder to build workflows. The method requires a step callbackid of type string. This callbackid must also be defined in your Function definition. Custom steps must be finalized using the complete() or fail() listener arguments to notify Slack that your app has processed the request.","source":"@site/content/concepts/custom-steps.md","sourceDirName":"concepts","slug":"/concepts/custom-steps","permalink":"/bolt-js/concepts/custom-steps","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/custom-steps.md","tags":[],"version":"current","frontMatter":{"title":"Custom Steps","lang":"en","slug":"/concepts/custom-steps"},"sidebar":"sidebarJSBolt","previous":{"title":"AI Apps","permalink":"/bolt-js/concepts/ai-apps"},"next":{"title":"Using Socket Mode","permalink":"/bolt-js/concepts/socket-mode"}},{"id":"concepts/deferring-initialization","title":"Deferring app initialization","description":"Bolt offers a way to defer full initialization via the deferInitialization option and to call the equivalent App#init() in your code, putting more control over asynchronous execution required for initialization into your hands as the developer.","source":"@site/content/concepts/deferring-initialization.md","sourceDirName":"concepts","slug":"/concepts/deferring-initialization","permalink":"/bolt-js/concepts/deferring-initialization","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/deferring-initialization.md","tags":[],"version":"current","frontMatter":{"title":"Deferring app initialization","lang":"en","slug":"/concepts/deferring-initialization"},"sidebar":"sidebarJSBolt","previous":{"title":"Adding custom HTTP routes","permalink":"/bolt-js/concepts/custom-routes"},"next":{"title":"Customizing a receiver","permalink":"/bolt-js/concepts/receiver"}},{"id":"concepts/error-handling","title":"Handling errors","description":"Since v2, error handling has improved! View the migration guide for V2 to learn about the changes.","source":"@site/content/concepts/error-handling.md","sourceDirName":"concepts","slug":"/concepts/error-handling","permalink":"/bolt-js/concepts/error-handling","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/error-handling.md","tags":[],"version":"current","frontMatter":{"title":"Handling errors","lang":"en","slug":"/concepts/error-handling"},"sidebar":"sidebarJSBolt","previous":{"title":"Using Socket Mode","permalink":"/bolt-js/concepts/socket-mode"},"next":{"title":"Logging","permalink":"/bolt-js/concepts/logging"}},{"id":"concepts/event-listening","title":"Listening to events","description":"You can listen to any Events API event using the event() method after subscribing to it in your app configuration. This allows your app to take action when something happens in Slack, like a user reacting to a message or joining a channel.","source":"@site/content/concepts/event-listening.md","sourceDirName":"concepts","slug":"/concepts/event-listening","permalink":"/bolt-js/concepts/event-listening","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/event-listening.md","tags":[],"version":"current","frontMatter":{"title":"Listening to events","lang":"en","slug":"/concepts/event-listening"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening to messages","permalink":"/bolt-js/concepts/message-listening"},"next":{"title":"Acknowledging requests","permalink":"/bolt-js/concepts/acknowledge"}},{"id":"concepts/global-middleware","title":"Global middleware","description":"Global middleware is run for all incoming requests before any listener middleware. You can add any number of global middleware to your app by utilizing app.use(fn). The middleware function fn is called with the same arguments as listeners and an additional next function.","source":"@site/content/concepts/global-middleware.md","sourceDirName":"concepts","slug":"/concepts/global-middleware","permalink":"/bolt-js/concepts/global-middleware","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/global-middleware.md","tags":[],"version":"current","frontMatter":{"title":"Global middleware","lang":"en","slug":"/concepts/global-middleware"},"sidebar":"sidebarJSBolt","previous":{"title":"Customizing a receiver","permalink":"/bolt-js/concepts/receiver"},"next":{"title":"Listener middleware","permalink":"/bolt-js/concepts/listener-middleware"}},{"id":"concepts/listener-middleware","title":"Listener middleware","description":"Listener middleware is used for logic across many listener functions (but usually not all of them). They are added as arguments before the listener function in one of the built-in methods. You can add any number of listener middleware before the listener function.","source":"@site/content/concepts/listener-middleware.md","sourceDirName":"concepts","slug":"/concepts/listener-middleware","permalink":"/bolt-js/concepts/listener-middleware","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/listener-middleware.md","tags":[],"version":"current","frontMatter":{"title":"Listener middleware","lang":"en","slug":"/concepts/listener-middleware"},"sidebar":"sidebarJSBolt","previous":{"title":"Global middleware","permalink":"/bolt-js/concepts/global-middleware"},"next":{"title":"Adding context","permalink":"/bolt-js/concepts/context"}},{"id":"concepts/logging","title":"Logging","description":"By default, Bolt for JavaScript will log information from your app to the console. You can customize how much logging occurs by passing a logLevel in the constructor. The available log levels in order of most to least logs are DEBUG, INFO, WARN, and ERROR.","source":"@site/content/concepts/logging.md","sourceDirName":"concepts","slug":"/concepts/logging","permalink":"/bolt-js/concepts/logging","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/logging.md","tags":[],"version":"current","frontMatter":{"title":"Logging","lang":"en","slug":"/concepts/logging"},"sidebar":"sidebarJSBolt","previous":{"title":"Handling errors","permalink":"/bolt-js/concepts/error-handling"},"next":{"title":"Adding custom HTTP routes","permalink":"/bolt-js/concepts/custom-routes"}},{"id":"concepts/message-listening","title":"Listening to messages","description":"To listen to messages that your app has access to receive, you can use the message() method which filters out events that aren’t of type message .A message() listener is equivalent to event('message')","source":"@site/content/concepts/message-listening.md","sourceDirName":"concepts","slug":"/concepts/message-listening","permalink":"/bolt-js/concepts/message-listening","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/message-listening.md","tags":[],"version":"current","frontMatter":{"title":"Listening to messages","lang":"en","slug":"/concepts/message-listening"},"sidebar":"sidebarJSBolt","previous":{"title":"Using the Web API","permalink":"/bolt-js/concepts/web-api"},"next":{"title":"Listening to events","permalink":"/bolt-js/concepts/event-listening"}},{"id":"concepts/message-sending","title":"Sending messages","description":"Within your listener function, say() is available whenever there is an associated conversation (for example, a conversation where the event or action which triggered the listener occurred). say() accepts a string to post simple messages and JSON payloads to send more complex messages. The message payload you pass in will be sent to the associated conversation.","source":"@site/content/concepts/message-sending.md","sourceDirName":"concepts","slug":"/concepts/message-sending","permalink":"/bolt-js/concepts/message-sending","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/message-sending.md","tags":[],"version":"current","frontMatter":{"title":"Sending messages","lang":"en","slug":"/concepts/message-sending"},"sidebar":"sidebarJSBolt","previous":{"title":"Getting Started","permalink":"/bolt-js/getting-started"},"next":{"title":"Using the Web API","permalink":"/bolt-js/concepts/web-api"}},{"id":"concepts/publishing-views","title":"Publishing views to App Home","description":"Home tabs are customizable surfaces accessible via the sidebar and search that allow apps to display views on a per-user basis. After enabling App Home within your app configuration, home tabs can be published and updated by passing a user_id and view payload to the views.publish method.","source":"@site/content/concepts/publishing-views.md","sourceDirName":"concepts","slug":"/concepts/publishing-views","permalink":"/bolt-js/concepts/publishing-views","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/publishing-views.md","tags":[],"version":"current","frontMatter":{"title":"Publishing views to App Home","lang":"en","slug":"/concepts/publishing-views"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening & responding to select menu options","permalink":"/bolt-js/concepts/options"},"next":{"title":"AI Apps","permalink":"/bolt-js/concepts/ai-apps"}},{"id":"concepts/receiver","title":"Customizing a receiver","description":"Writing a custom receiver","source":"@site/content/concepts/receiver.md","sourceDirName":"concepts","slug":"/concepts/receiver","permalink":"/bolt-js/concepts/receiver","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/receiver.md","tags":[],"version":"current","frontMatter":{"title":"Customizing a receiver","lang":"en","slug":"/concepts/receiver"},"sidebar":"sidebarJSBolt","previous":{"title":"Deferring app initialization","permalink":"/bolt-js/concepts/deferring-initialization"},"next":{"title":"Global middleware","permalink":"/bolt-js/concepts/global-middleware"}},{"id":"concepts/select-menu-options","title":"Listening & responding to select menu options","description":"The options() method listens for incoming option request payloads from Slack. Similar to the action() method,","source":"@site/content/concepts/select-menu-options.md","sourceDirName":"concepts","slug":"/concepts/options","permalink":"/bolt-js/concepts/options","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/select-menu-options.md","tags":[],"version":"current","frontMatter":{"title":"Listening & responding to select menu options","lang":"en","slug":"/concepts/options"},"sidebar":"sidebarJSBolt","previous":{"title":"Listening to views","permalink":"/bolt-js/concepts/view-submissions"},"next":{"title":"Publishing views to App Home","permalink":"/bolt-js/concepts/publishing-views"}},{"id":"concepts/shortcuts","title":"Listening & responding to shortcuts","description":"The shortcut() method supports both global shortcuts and message shortcuts.","source":"@site/content/concepts/shortcuts.md","sourceDirName":"concepts","slug":"/concepts/shortcuts","permalink":"/bolt-js/concepts/shortcuts","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/shortcuts.md","tags":[],"version":"current","frontMatter":{"title":"Listening & responding to shortcuts","lang":"en","slug":"/concepts/shortcuts"},"sidebar":"sidebarJSBolt","previous":{"title":"Acknowledging requests","permalink":"/bolt-js/concepts/acknowledge"},"next":{"title":"Listening & responding to commands","permalink":"/bolt-js/concepts/commands"}},{"id":"concepts/socket-mode","title":"Using Socket Mode","description":"Socket Mode allows your app to connect and receive data from Slack via a WebSocket connection. To handle the connection, Bolt for JavaScript includes a SocketModeReceiver (in @slack/bolt@3.0.0 and higher). Before using Socket Mode, be sure to enable it within your app configuration.","source":"@site/content/concepts/socket-mode.md","sourceDirName":"concepts","slug":"/concepts/socket-mode","permalink":"/bolt-js/concepts/socket-mode","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/socket-mode.md","tags":[],"version":"current","frontMatter":{"title":"Using Socket Mode","lang":"en","slug":"/concepts/socket-mode"},"sidebar":"sidebarJSBolt","previous":{"title":"Custom Steps","permalink":"/bolt-js/concepts/custom-steps"},"next":{"title":"Handling errors","permalink":"/bolt-js/concepts/error-handling"}},{"id":"concepts/token-rotation","title":"Token rotation","description":"Supported in Bolt for JavaScript as of v3.5.0, token rotation provides an extra layer of security for your access tokens and is defined by the OAuth V2 RFC.","source":"@site/content/concepts/token-rotation.md","sourceDirName":"concepts","slug":"/concepts/token-rotation","permalink":"/bolt-js/concepts/token-rotation","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/token-rotation.md","tags":[],"version":"current","frontMatter":{"title":"Token rotation","lang":"en","slug":"/concepts/token-rotation"},"sidebar":"sidebarJSBolt","previous":{"title":"Authorization","permalink":"/bolt-js/concepts/authorization"},"next":{"title":"Deploying to AWS Lambda","permalink":"/bolt-js/deployments/aws-lambda"}},{"id":"concepts/updating-pushing-views","title":"Updating & pushing views","description":"Modals contain a stack of views. When you call the views.open method, you add the root view to the modal. After the initial call, you can dynamically update a view by calling the views.update method, or stack a new view on top of the root view by calling the views.push method.","source":"@site/content/concepts/updating-pushing-views.md","sourceDirName":"concepts","slug":"/concepts/updating-pushing-views","permalink":"/bolt-js/concepts/updating-pushing-views","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/updating-pushing-views.md","tags":[],"version":"current","frontMatter":{"title":"Updating & pushing views","lang":"en","slug":"/concepts/updating-pushing-views"},"sidebar":"sidebarJSBolt","previous":{"title":"Opening modals","permalink":"/bolt-js/concepts/creating-modals"},"next":{"title":"Listening to views","permalink":"/bolt-js/concepts/view-submissions"}},{"id":"concepts/view-submissions","title":"Listening to views","description":"You may listen for user interactions with views using the view method.","source":"@site/content/concepts/view-submissions.md","sourceDirName":"concepts","slug":"/concepts/view-submissions","permalink":"/bolt-js/concepts/view-submissions","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/view-submissions.md","tags":[],"version":"current","frontMatter":{"title":"Listening to views","lang":"en","slug":"/concepts/view-submissions"},"sidebar":"sidebarJSBolt","previous":{"title":"Updating & pushing views","permalink":"/bolt-js/concepts/updating-pushing-views"},"next":{"title":"Listening & responding to select menu options","permalink":"/bolt-js/concepts/options"}},{"id":"concepts/web-api","title":"Using the Web API","description":"You can call any Web API method using the WebClient provided to your app's listeners as client. This uses either the token that initialized your app or the token that is returned from the authorize function for the incoming event. The built-in OAuth support handles the second case by default.","source":"@site/content/concepts/web-api.md","sourceDirName":"concepts","slug":"/concepts/web-api","permalink":"/bolt-js/concepts/web-api","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/concepts/web-api.md","tags":[],"version":"current","frontMatter":{"title":"Using the Web API","lang":"en","slug":"/concepts/web-api"},"sidebar":"sidebarJSBolt","previous":{"title":"Sending messages","permalink":"/bolt-js/concepts/message-sending"},"next":{"title":"Listening to messages","permalink":"/bolt-js/concepts/message-listening"}},{"id":"deployments/aws-lambda","title":"Deploying to AWS Lambda","description":"This guide walks you through preparing and deploying a Slack app using Bolt for JavaScript, the Serverless Framework, and AWS Lambda.","source":"@site/content/deployments/aws-lambda.md","sourceDirName":"deployments","slug":"/deployments/aws-lambda","permalink":"/bolt-js/deployments/aws-lambda","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/deployments/aws-lambda.md","tags":[],"version":"current","frontMatter":{"title":"Deploying to AWS Lambda","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Token rotation","permalink":"/bolt-js/concepts/token-rotation"},"next":{"title":"Deploying to Heroku","permalink":"/bolt-js/deployments/heroku"}},{"id":"deployments/heroku","title":"Deploying to Heroku","description":"This guide will walk you through preparing and deploying a Slack app using Bolt for JavaScript and the Heroku platform. Along the way, we’ll download a Bolt Slack app, prepare it for Heroku, and deploy it.","source":"@site/content/deployments/heroku.md","sourceDirName":"deployments","slug":"/deployments/heroku","permalink":"/bolt-js/deployments/heroku","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/deployments/heroku.md","tags":[],"version":"current","frontMatter":{"title":"Deploying to Heroku","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Deploying to AWS Lambda","permalink":"/bolt-js/deployments/aws-lambda"},"next":{"title":"Migrating to V2","permalink":"/bolt-js/tutorial/migration-v2"}},{"id":"getting-started","title":"Getting started with Bolt for JavaScript","description":"This guide is meant to walk you through getting up and running with a Slack app using Bolt for JavaScript. Along the way, we’ll create a new Slack app, set up your local environment, and develop an app that listens and responds to messages from a Slack workspace.","source":"@site/content/getting-started.mdx","sourceDirName":".","slug":"/getting-started","permalink":"/bolt-js/getting-started","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/getting-started.mdx","tags":[],"version":"current","frontMatter":{"title":"Getting started with Bolt for JavaScript","sidebar_label":"Getting Started"},"sidebar":"sidebarJSBolt","previous":{"title":"Bolt for JavaScript","permalink":"/bolt-js/"},"next":{"title":"Sending messages","permalink":"/bolt-js/concepts/message-sending"}},{"id":"index","title":"Bolt for JavaScript","description":"Bolt for JavaScript is a JavaScript framework to build Slack apps with the latest Slack platform features. Read the Getting Started Guide to set up and run your first Bolt app.","source":"@site/content/index.md","sourceDirName":".","slug":"/","permalink":"/bolt-js/","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/index.md","tags":[],"version":"current","frontMatter":{},"sidebar":"sidebarJSBolt","next":{"title":"Getting Started","permalink":"/bolt-js/getting-started"}},{"id":"legacy/conversation-store","title":"Conversation stores","description":"Bolt for JavaScript includes support for a store, which sets and retrieves state related to a conversation.","source":"@site/content/legacy/conversation-store.md","sourceDirName":"legacy","slug":"/concepts/conversation-store","permalink":"/bolt-js/concepts/conversation-store","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/legacy/conversation-store.md","tags":[],"version":"current","frontMatter":{"title":"Conversation stores","lang":"en","slug":"/concepts/conversation-store"},"sidebar":"sidebarJSBolt","previous":{"title":"Steps from Apps","permalink":"/bolt-js/legacy/steps-from-apps"},"next":{"title":"Reference","permalink":"/bolt-js/reference"}},{"id":"legacy/hubot-migration","title":"Migrating apps from Hubot to Bolt for JavaScript","description":"Bolt was created to reduce the time and complexity it takes to build Slack apps. It provides Slack developers a single interface to build using modern features and best practices. This guide is meant to step you through the process of migrating your app from using Hubot to Bolt for JavaScript.","source":"@site/content/legacy/hubot-migration.md","sourceDirName":"legacy","slug":"/tutorial/hubot-migration","permalink":"/bolt-js/tutorial/hubot-migration","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/legacy/hubot-migration.md","tags":[],"version":"current","frontMatter":{"title":"Migrating apps from Hubot to Bolt for JavaScript","sidebar_label":"Hubot app migration","slug":"/tutorial/hubot-migration","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Migrating to V4","permalink":"/bolt-js/tutorial/migration-v4"},"next":{"title":"Steps from Apps","permalink":"/bolt-js/legacy/steps-from-apps"}},{"id":"legacy/steps-from-apps","title":"Steps from Apps","description":"Steps from Apps is a deprecated feature.","source":"@site/content/legacy/steps-from-apps.md","sourceDirName":"legacy","slug":"/legacy/steps-from-apps","permalink":"/bolt-js/legacy/steps-from-apps","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/legacy/steps-from-apps.md","tags":[],"version":"current","frontMatter":{"title":"Steps from Apps","lang":"en","slug":"/legacy/steps-from-apps"},"sidebar":"sidebarJSBolt","previous":{"title":"Hubot app migration","permalink":"/bolt-js/tutorial/hubot-migration"},"next":{"title":"Conversation stores","permalink":"/bolt-js/concepts/conversation-store"}},{"id":"migration/migration-v2","title":"Migrating to V2","description":"End of life for @slack/bolt@1.x was  April 30th, 2021. Development has been fully stopped for @slack/bolt@1.x and all remaining open issues and pull requests have been closed.","source":"@site/content/migration/migration-v2.md","sourceDirName":"migration","slug":"/tutorial/migration-v2","permalink":"/bolt-js/tutorial/migration-v2","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/migration/migration-v2.md","tags":[],"version":"current","frontMatter":{"title":"Migrating to V2","slug":"/tutorial/migration-v2","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Deploying to Heroku","permalink":"/bolt-js/deployments/heroku"},"next":{"title":"Migrating to V3","permalink":"/bolt-js/tutorial/migration-v3"}},{"id":"migration/migration-v3","title":"Migrating to V3","description":"End of life for @slack/bolt@2.x was May 31st, 2021. Development has been fully stopped for @slack/bolt@2.x and all remaining open issues and pull requests have been closed.","source":"@site/content/migration/migration-v3.md","sourceDirName":"migration","slug":"/tutorial/migration-v3","permalink":"/bolt-js/tutorial/migration-v3","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/migration/migration-v3.md","tags":[],"version":"current","frontMatter":{"title":"Migrating to V3","slug":"/tutorial/migration-v3","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Migrating to V2","permalink":"/bolt-js/tutorial/migration-v2"},"next":{"title":"Migrating to V4","permalink":"/bolt-js/tutorial/migration-v4"}},{"id":"migration/migration-v4","title":"Migrating to V4","description":"This guide will walk you through the process of updating your app from using @slack/bolt@3.x to @slack/bolt@4.x. There may be a few changes you'll need to make depending on which features you use, but for most apps, these changes can be applied in a few minutes. Some apps may need no changes at all.","source":"@site/content/migration/migration-v4.md","sourceDirName":"migration","slug":"/tutorial/migration-v4","permalink":"/bolt-js/tutorial/migration-v4","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/migration/migration-v4.md","tags":[],"version":"current","frontMatter":{"title":"Migrating to V4","slug":"/tutorial/migration-v4","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Migrating to V3","permalink":"/bolt-js/tutorial/migration-v3"},"next":{"title":"Hubot app migration","permalink":"/bolt-js/tutorial/hubot-migration"}},{"id":"reference","title":"Bolt for JavaScript interface and configuration reference","description":"This guide is intended to detail the Bolt interface–including listeners and their arguments, initialization options, and errors. It may be helpful to first go through the ⚡️Getting Started guide to learn the basics of building Bolt for JavaScript apps.","source":"@site/content/reference.md","sourceDirName":".","slug":"/reference","permalink":"/bolt-js/reference","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/reference.md","tags":[],"version":"current","frontMatter":{"title":"Bolt for JavaScript interface and configuration reference","sidebar_label":"Reference","slug":"reference","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Conversation stores","permalink":"/bolt-js/concepts/conversation-store"},"next":{"title":"AI Assistant","permalink":"/bolt-js/tutorials/ai-assistant"}},{"id":"tutorials/ai-assistant","title":"AI Assistant","description":"In this tutorial, you will create an app, enable the features to make it an AI app, and explore adding code to set suggested prompts, respond to assistant-related events, and integrate an LLM with which you can correspond.","source":"@site/content/tutorials/ai-assistant.md","sourceDirName":"tutorials","slug":"/tutorials/ai-assistant","permalink":"/bolt-js/tutorials/ai-assistant","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/tutorials/ai-assistant.md","tags":[],"version":"current","frontMatter":{"title":"AI Assistant","slug":"/tutorials/ai-assistant","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"Reference","permalink":"/bolt-js/reference"},"next":{"title":"AI Code Assistant with Hugging Face","permalink":"/bolt-js/tutorials/code-assistant"}},{"id":"tutorials/code-assistant","title":"AI Code Assistant with Hugging Face","description":"In this tutorial, we will create an AI app with the Bolt framework and integrate a Hugging Face model to assist the user with coding questions. We'll also make this functionality available as a step in a workflow to use in Workflow Builder.","source":"@site/content/tutorials/code-assistant.md","sourceDirName":"tutorials","slug":"/tutorials/code-assistant","permalink":"/bolt-js/tutorials/code-assistant","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/tutorials/code-assistant.md","tags":[],"version":"current","frontMatter":{"title":"AI Code Assistant with Hugging Face","slug":"/tutorials/code-assistant","lang":"en"},"sidebar":"sidebarJSBolt","previous":{"title":"AI Assistant","permalink":"/bolt-js/tutorials/ai-assistant"},"next":{"title":"Custom Steps","permalink":"/bolt-js/tutorials/custom-steps"}},{"id":"tutorials/custom-steps","title":"Custom Steps","description":"If you don't have a paid workspace for development, you can join the Developer Program and provision a sandbox with access to all Slack features for free.","source":"@site/content/tutorials/custom-steps.md","sourceDirName":"tutorials","slug":"/tutorials/custom-steps","permalink":"/bolt-js/tutorials/custom-steps","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/tutorials/custom-steps.md","tags":[],"version":"current","frontMatter":{"title":"Custom Steps"},"sidebar":"sidebarJSBolt","previous":{"title":"AI Code Assistant with Hugging Face","permalink":"/bolt-js/tutorials/code-assistant"},"next":{"title":"Custom Steps for Workflow Builder (new app)","permalink":"/bolt-js/tutorials/custom-steps-workflow-builder-new"}},{"id":"tutorials/custom-steps-workflow-builder-existing","title":"Custom Steps for Workflow Builder (existing app)","description":"If you don't have a paid workspace for development, you can join the Developer Program and provision a sandbox with access to all Slack features for free.","source":"@site/content/tutorials/custom-steps-workflow-builder-existing.md","sourceDirName":"tutorials","slug":"/tutorials/custom-steps-workflow-builder-existing","permalink":"/bolt-js/tutorials/custom-steps-workflow-builder-existing","draft":false,"unlisted":false,"editUrl":"https://github.com/slackapi/bolt-js/tree/main/docs/content/tutorials/custom-steps-workflow-builder-existing.md","tags":[],"version":"current","frontMatter":{"title":"Custom Steps for Workflow Builder (existing ap